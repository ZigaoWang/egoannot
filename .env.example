# Copy to .env and edit. All keys prefixed EGOANNOT_ override the equivalent
# nested config.yaml setting via a double underscore separator.
#
# Example: EGOANNOT_VLM__BASE_URL overrides settings.vlm.base_url

# --- VLM server (must be running externally; the pipeline does NOT launch it) ---
EGOANNOT_VLM__BASE_URL=http://localhost:8000/v1
EGOANNOT_VLM__MODEL=Qwen3-VL-32B-Instruct
EGOANNOT_VLM__TIMEOUT_SEC=120
EGOANNOT_VLM__MAX_RETRIES=2

# --- Paths (defaults are relative to CWD; override to point at a data volume) ---
# EGOANNOT_PATHS__ROOT=/data/keyframe
# EGOANNOT_PATHS__DATA_DIR=/data/keyframe/data
# EGOANNOT_PATHS__LOG_DIR=/data/keyframe/logs

# --- Runtime knobs ---
EGOANNOT_RUNTIME__CONCURRENCY=4
EGOANNOT_RUNTIME__LOG_LEVEL=INFO
