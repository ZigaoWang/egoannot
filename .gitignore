# ------------------------------------------------------------------- Python
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
*.whl
*.tar.gz

# Virtualenvs
.venv/
venv/
env/
.python-version

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# ------------------------------------------------------------------- Project
# Pipeline artefacts. This repo never ships videos, frames, DB, or annotations.
data/
logs/
outputs/

# Explicit belt-and-suspenders for common child paths in case someone reroutes
# the project root but forgets to update .gitignore.
**/data/pipeline.db
**/data/frames/
**/data/videos/
**/data/raw/
**/data/outputs/
*.mp4
*.mov
*.mkv
*.avi
*.webm
*.jpg
*.jpeg
*.png
!docs/**/*.png
!docs/**/*.jpg

# ------------------------------------------------------------------- Secrets
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
service-account*.json

# ------------------------------------------------------------------- Models
# vLLM / HF weights live outside the repo; guard against accidentally
# copying a checkpoint into the working tree.
models/
weights/
checkpoints/
*.bin
*.safetensors
*.gguf
*.onnx
*.pt
*.pth

# ------------------------------------------------------------------- Streamlit
.streamlit/secrets.toml

# ------------------------------------------------------------------- Node (if a UI is ever added)
node_modules/
